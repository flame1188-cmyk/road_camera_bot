# Telegram Bot
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Доступ пользователей (пусто = разрешено всем, через запятую)
ALLOWED_USER_IDS=

# VLM API (GLM-4V) для анализа изображений
VLM_API_KEY=your_vlm_api_key_here
VLM_API_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
VLM_MODEL=glm-4v-flash

# LLM API (GLM текстовый) для аналитики (можно совпадать с VLM_API_KEY)
LLM_API_KEY=your_llm_api_key_here

# HTTP Proxy (опционально, для корпоративных сетей)
HTTP_PROXY=
HTTPS_PROXY=

# Настройки
TARGET_API_TIMEOUT=60
ENABLE_NEWS_SEARCH=false
